<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="WishListClient.src.Components.ImageLoaderButton"
             x:Name="Root">

    <Border StrokeShape="RoundRectangle 20" 
            StrokeThickness="2"
            Stroke="{StaticResource Primary}"
            BackgroundColor="{StaticResource LightGray}"
            WidthRequest="{Binding ButtonSize}"
            HeightRequest="{Binding ButtonSize}"
            HorizontalOptions="Center"
            VerticalOptions="Center"
            Clip="RoundRectangle 20">

        <Border.Shadow>
            <Shadow Brush="Black" Offset="2,2" Radius="4" Opacity="0.3"/>
        </Border.Shadow>

        <Border.Behaviors>
            <toolkit:TouchBehavior 
                Command="{Binding Source={x:Reference Root}, Path=Command}"
                CommandParameter="{Binding Source={x:Reference Root}, Path=CommandParameter}"
                PressedScale="0.9" />
        </Border.Behaviors>

        <Grid>
            <Image Source="{Binding PhotoSource}"
                   Aspect="AspectFill"
                   HorizontalOptions="Fill"
                   VerticalOptions="Fill">
            </Image>

            <Path Data="{Binding IconData}"
                  Fill="{Binding IconColor}"
                  Aspect="Uniform"
                  WidthRequest="30"
                  HeightRequest="30"
                  HorizontalOptions="Center"
                  VerticalOptions="Center"/>
        </Grid>
    </Border>
</ContentView>