<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:Component="clr-namespace:WishListClient.src.Components"
             x:Class="WishListClient.src.Pages.DetailsPage">
    <VerticalStackLayout>
        <Border StrokeShape="RoundRectangle 0 0 20 20" 
                StrokeThickness="2"
                Stroke="{StaticResource Primary}"
                HeightRequest="200"
                HorizontalOptions="Fill"
                VerticalOptions="Center">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="2,2" Radius="4" Opacity="0.3"/>
            </Border.Shadow>

            <Image Source="{Binding Image}"
                   Aspect="AspectFill"
                   HorizontalOptions="Fill"
                   VerticalOptions="Fill">
            </Image>
        </Border>

        <VerticalStackLayout Grid.Column="1" Margin="10"
                             VerticalOptions="Center">
            <HorizontalStackLayout Spacing="5" >
                <Label Text="{Binding Wish.Title, Mode=TwoWay}"
                   FontSize="26"/>

                <Component:IconButton Data="{StaticResource Edit}"
                                      BackgroundColor="Transparent"
                                      IconColor="{StaticResource White}"
                                      BorderThickness="0"
                                      Command="{Binding BindingContext.GoToEditCommand, Source={RelativeSource AncestorType={x:Type ContentPage}}}"
                                      ButtonSize="30"
                                      IconSize="25"/>

                <Component:IconButton Data="{StaticResource Delete}"
                                      BackgroundColor="Transparent"
                                      IconColor="{StaticResource White}"
                                      BorderThickness="0"
                                      Command="{Binding BindingContext.OnDeleteCommand, Source={RelativeSource AncestorType={x:Type ContentPage}}}"
                                      ButtonSize="30"
                                      IconSize="25"/>
            </HorizontalStackLayout>

            <Label Text="{Binding Wish.Description, Mode=TwoWay}"
                   FontSize="16" Margin="0, 5, 0, 0"/>
        </VerticalStackLayout>

        <HorizontalStackLayout VerticalOptions="Center"
                               Margin="0, -5, 0, 15">
            <CheckBox IsChecked="{Binding Wish.IsReceived, Mode=TwoWay}"
                      IsEnabled="False"/>
            <Label Text="Получено"
                   VerticalTextAlignment="Center"/>
        </HorizontalStackLayout>

        <Button Command="{Binding GoToBackCommand}"
                Text="Назад"
                Margin="30, 0"/>

    </VerticalStackLayout>
</ContentPage>